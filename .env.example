# EmailJS Integration (Option 1)
# Create a free account at https://www.emailjs.com/ and configure your variables:
REACT_APP_EMAILJS_SERVICE_ID=your_service_id_here
REACT_APP_EMAILJS_TEMPLATE_ID=your_template_id_here
REACT_APP_EMAILJS_AUTOREPLY_TEMPLATE_ID=your_autoreply_template_id_here
REACT_APP_EMAILJS_PUBLIC_KEY=your_public_key_here

# Web3Forms Integration (Option 2)
# Get a free access key instantly at https://web3forms.com/
REACT_APP_WEB3FORMS_KEY=your_web3forms_key_here
